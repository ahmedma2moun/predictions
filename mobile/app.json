{
  "expo": {
    "name": "Football Predictions",
    "slug": "football-predictions",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "footballpredictions",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "ios": {
      "bundleIdentifier": "com.maamoun.footballpredictions",
      "supportsTablet": true,
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.maamoun.footballpredictions",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0b1220"
      },
      "permissions": [
        "POST_NOTIFICATIONS",
        "INTERNET"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "./plugins/withFirebaseNotificationColor",
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#10b981"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#0b1220"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24,
            "kotlinVersion": "1.9.24"
          },
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      "expo-font"
    ],
    "extra": {
      "apiBaseUrl": "https://predictions-virid.vercel.app",
      "apiBaseUrlDev": "https://predictions-virid.vercel.app",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "9960a25c-d1cf-40e8-b03b-d1c3eb2c2950"
      }
    },
    "experiments": {
      "typedRoutes": true
    },
    "owner": "ahmdma2mou"
  }
}
