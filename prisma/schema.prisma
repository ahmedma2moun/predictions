generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  admin
  user
}

enum MatchStatus {
  scheduled
  live
  finished
  postponed
  cancelled
}

enum Winner {
  home
  away
  draw
}

model User {
  id           Int           @id @default(autoincrement())
  name         String
  email        String        @unique
  password     String
  role         Role          @default(user)
  avatarUrl         String?
  notificationEmail String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  predictions  Prediction[]
  groupMembers GroupMember[]
  deviceTokens DeviceToken[]
}

model League {
  id          Int          @id @default(autoincrement())
  externalId  Int          @unique
  name        String
  country     String
  logo        String?
  season      Int
  isActive    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  teamLeagues TeamLeague[]
  matches     Match[]
}

model Team {
  id          Int          @id @default(autoincrement())
  externalId  Int          @unique
  name        String
  logo        String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  teamLeagues TeamLeague[]
}

model TeamLeague {
  id               Int      @id @default(autoincrement())
  teamId           Int
  team             Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  leagueId         Int
  league           League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  externalLeagueId Int
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([teamId, leagueId])
  @@index([leagueId])
  @@index([externalLeagueId])
}

model Match {
  id               Int          @id @default(autoincrement())
  externalId       Int          @unique
  leagueId         Int?
  league           League?      @relation(fields: [leagueId], references: [id], onDelete: SetNull)
  externalLeagueId Int
  homeTeamExtId    Int
  homeTeamName     String
  homeTeamLogo     String?
  awayTeamExtId    Int
  awayTeamName     String
  awayTeamLogo     String?
  kickoffTime      DateTime
  status           MatchStatus  @default(scheduled)
  matchday         Int?
  stage            String?
  leg              Int?
  venue            String?
  resultHomeScore        Int?
  resultAwayScore        Int?
  resultPenaltyHomeScore Int?
  resultPenaltyAwayScore Int?
  resultWinner           Winner?
  scoresProcessed  Boolean      @default(false)
  weekStart        DateTime
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  predictions      Prediction[]

  @@index([status, kickoffTime])
  @@index([externalLeagueId, kickoffTime])
}

model Prediction {
  id               Int      @id @default(autoincrement())
  userId           Int
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchId          Int
  match            Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  homeScore        Int
  awayScore        Int
  predictedWinner  Winner
  pointsAwarded    Int      @default(0)
  scoringBreakdown Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, matchId])
  @@index([matchId])
  @@index([userId, createdAt(sort: Desc)])
}

model ScoringRule {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  key         String   @unique
  points      Int
  priority    Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Group {
  id        Int           @id @default(autoincrement())
  name      String
  isDefault Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  members   GroupMember[]
}

model GroupMember {
  id      Int   @id @default(autoincrement())
  groupId Int
  group   Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId  Int
  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model TeamStanding {
  id               Int      @id @default(autoincrement())
  externalTeamId   Int
  externalLeagueId Int
  season           Int
  position         Int
  played           Int
  won              Int
  drawn            Int
  lost             Int
  points           Int
  goalsFor         Int
  goalsAgainst     Int
  goalDifference   Int
  form             String?
  updatedAt        DateTime @updatedAt

  @@unique([externalTeamId, externalLeagueId])
}

model DeviceToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String   @default("android")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}
